rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    match /users/{userId} {
      allow read: if request.auth != null;
      // Allow create: only super admin can create with 'officer' or 'worker' directly, others can only create citizen or pending roles
      allow create: if request.auth != null && request.auth.uid == userId && (
        request.auth.token.email == 'saketsagar004@gmail.com' || 
        request.resource.data.role in ['citizen', 'pending_officer', 'pending_worker']
      );
      // Allow update: super admin can update anything, user can update their own profile as long as role doesn't change
      allow update: if request.auth != null && (
        request.auth.token.email == 'saketsagar004@gmail.com' ||
        (request.auth.uid == userId && request.resource.data.role == resource.data.role)
      );
    }
  }
}
